{%- set siteUrl = "https://kcjugran.github.io/articles" -%}
{%- set pageUrl = siteUrl + page.url -%}
{%- set pageDescription = content | excerpt(160) -%}
{%- set ogImage = (siteUrl + "/assets/logo.jpg") -%}
{%- if youtubeId %}{%- set ogImage = "https://i.ytimg.com/vi/" + youtubeId + "/hqdefault.jpg" -%}{% endif -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} · Living Foundations</title>
  <meta name="description" content="{{ pageDescription }}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{ pageUrl }}">
  <link rel="icon" href="{{ '/assets/logo.jpg' | url }}" type="image/jpeg">
  <link rel="apple-touch-icon" href="{{ '/assets/logo.jpg' | url }}">

  <meta property="og:site_name" content="Living Foundations">
  <meta property="og:title" content="{{ title }} · Living Foundations">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:type" content="{{ 'video.other' if youtubeId else 'website' }}">
  <meta property="og:image" content="{{ ogImage }}">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} · Living Foundations">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ ogImage }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/assets/css/bundle.css' | url }}">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Karan Chandra Jugran",
    "url": "{{ siteUrl }}/",
    "sameAs": [
      "https://www.youtube.com/channel/UC6FA5t7Ywxjj-76uYSppNWQ",
      "https://www.instagram.com/karan_chandra_jugran/",
      "https://x.com/KJugran53679"
    ],
    "jobTitle": "Health & Wellness Coach",
    "worksFor": {
      "@type": "Organization",
      "name": "Living Foundations"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Living Foundations",
    "url": "{{ siteUrl }}/",
    "description": "Practical wellness, movement, and mind-body guidance from Karan Chandra Jugran — video companion articles covering fitness form, breathing, sleep, injury recovery, and psychology.",
    "publisher": {
      "@type": "Organization",
      "name": "Living Foundations",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ siteUrl }}/assets/logo.jpg"
      }
    }
  }
  </script>
  {% if youtubeId %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ title | dump | safe }},
    "description": {{ pageDescription | dump | safe }},
    "url": "{{ pageUrl }}",
    "image": "{{ ogImage }}",
    "author": {
      "@type": "Person",
      "name": "Karan Chandra Jugran"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Living Foundations",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ siteUrl }}/assets/logo.jpg"
      }
    },
    "mainEntityOfPage": "{{ pageUrl }}"
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": {{ title | dump | safe }},
    "description": {{ pageDescription | dump | safe }},
    "thumbnailUrl": "{{ ogImage }}",
    "embedUrl": "https://www.youtube.com/embed/{{ youtubeId }}",
    {% if durationIso %}"duration": "{{ durationIso }}",{% endif %}
    "publisher": {
      "@type": "Organization",
      "name": "Living Foundations",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ siteUrl }}/assets/logo.jpg"
      }
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ siteUrl }}/"},
      {"@type": "ListItem", "position": 2, "name": "Video Articles", "item": "{{ siteUrl }}/videos/"},
      {"@type": "ListItem", "position": 3, "name": {{ title | dump | safe }}, "item": "{{ pageUrl }}"}
    ]
  }
  </script>
  {% endif %}
</head>
<body class="{{ bodyWidth or 'narrow' }}">
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-header">
    <a href="{{ '/' | url }}" class="brand">
      <img src="{{ '/assets/logo.jpg' | url }}" alt="Living Foundations" class="logo">
      <span class="brand-text">
        <span class="brand-name">Living Foundations</span>
        <span class="brand-tagline">start with the basics</span>
      </span>
    </a>
    <nav class="site-nav">
      <a href="{{ '/videos/' | url }}">Video Articles</a>
      <a href="/coaching/">Personal Coaching</a>
      <a href="/clarity/" target="_blank" rel="noopener">Get Clarity</a>
      <a href="/course/" target="_blank" rel="noopener">PT Course</a>
    </nav>
  </header>
  <main id="main">
    {{ content | safe }}
  </main>
  <div class="coaching-cta-band">
    <p>Want hands-on guidance instead of going it alone? <a href="/coaching/">Work with KC 1:1 &rarr;</a></p>
  </div>
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="{{ '/assets/logo.jpg' | url }}" alt="Living Foundations" class="footer-logo">
        <div>
          <span class="footer-brand-name">Living Foundations</span>
          <span class="footer-tagline">start with the basics</span>
        </div>
      </div>
      <nav class="footer-links" aria-label="Footer">
        <a href="{{ '/' | url }}">Home</a>
        <a href="{{ '/videos/' | url }}">Video Articles</a>
        <a href="/clarity/" target="_blank" rel="noopener">Get Clarity</a>
        <a href="/course/" target="_blank" rel="noopener">PT Course</a>
        <a href="/coaching/">1:1 Coaching</a>
      </nav>
      <div class="footer-social">
        <a href="https://www.instagram.com/karan_chandra_jugran/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a href="https://x.com/KJugran53679" target="_blank" rel="noopener" aria-label="X (Twitter)">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.9 2H22l-7.6 8.7L23.3 22h-7.2l-5.6-6.9L4 22H1l8.1-9.3L0.8 2h7.4l5.1 6.3L18.9 2zm-1.3 18h2L6.5 4h-2l13.1 16z"/>
          </svg>
        </a>
        <a href="https://www.youtube.com/channel/UC6FA5t7Ywxjj-76uYSppNWQ" target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.6 31.6 0 0 0 0 12a31.6 31.6 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.6 31.6 0 0 0 24 12a31.6 31.6 0 0 0-.5-5.8zM9.6 15.5V8.5L15.8 12z"/>
          </svg>
        </a>
      </div>
    </div>
    <p class="footer-copyright">&copy; {{ year }} Living Foundations</p>
  </footer>

  <div class="social-bar">
    <a href="https://www.instagram.com/karan_chandra_jugran/" target="_blank" rel="noopener" aria-label="Instagram">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5"/>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
      </svg>
    </a>
    <a href="https://x.com/KJugran53679" target="_blank" rel="noopener" aria-label="X (Twitter)">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.9 2H22l-7.6 8.7L23.3 22h-7.2l-5.6-6.9L4 22H1l8.1-9.3L0.8 2h7.4l5.1 6.3L18.9 2zm-1.3 18h2L6.5 4h-2l13.1 16z"/>
      </svg>
    </a>
    <a href="https://www.youtube.com/channel/UC6FA5t7Ywxjj-76uYSppNWQ" target="_blank" rel="noopener" aria-label="YouTube">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.6 31.6 0 0 0 0 12a31.6 31.6 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.6 31.6 0 0 0 24 12a31.6 31.6 0 0 0-.5-5.8zM9.6 15.5V8.5L15.8 12z"/>
      </svg>
    </a>
  </div>
</body>
</html>
